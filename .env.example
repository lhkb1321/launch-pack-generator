# AI 出海 Launch Pack 生成器 - 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ===========================================
# AI 配置
# ===========================================

# OpenAI API Key (二选一，优先使用 OpenAI)
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Claude API Key (备选方案)
# 获取地址：https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ===========================================
# 支付配置 (Stripe)
# ===========================================

# Stripe Secret Key (用于服务端 API 调用)
# 获取地址：https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# Stripe Publishable Key (用于前端)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Stripe Webhook Secret (用于接收支付回调)
# 获取地址：https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ===========================================
# 数据库配置 (SQLite)
# ===========================================

# SQLite 数据库文件路径 (本地开发)
DATABASE_URL=file:./dev.db

# 生产环境数据库路径 (可选)
# DATABASE_URL=file:/var/data/launch-pack-generator.db

# ===========================================
# 应用配置
# ===========================================

# 应用运行环境
NEXT_PUBLIC_APP_ENV=development

# 应用基础 URL (生产环境修改)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 会话密钥 (用于加密，生成随机字符串)
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here-change-in-production

# ===========================================
# 可选配置
# ===========================================

# 邮件服务 (用于发送支付确认邮件，可选)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-email-password

# 分析服务 (可选)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
















































